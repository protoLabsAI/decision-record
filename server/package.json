{
  "name": "@protolabs/decision-record-server",
  "version": "0.1.0",
  "description": "MCP server for the decision-record idea-to-MVP planning pipeline.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "decision-record-mcp": "dist/index.js",
    "decision-record": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "seed",
    "schemas"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test tests/unit-*.test.ts tests/flow-*.test.ts 2>&1 | grep -v 'ExperimentalWarning' || true",
    "test:unit": "node --import tsx/esm --test tests/unit-*.test.ts",
    "test:flow": "node --import tsx/esm --test tests/flow-*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "nanoid": "^5.0.0",
    "openai": "^6.38.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
